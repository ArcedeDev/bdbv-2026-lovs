      "challenges": [
        {
          "topic": "post_mortem_swab_reluctance",
          "finding": "Reluctance to post-mortem swabbing can delay confirmation and underestimate cases.",
          "response": "Intensify community engagement and involve religious leaders."
        },
        {
          "topic": "cte_capacity",
          "finding": "Normed CTE capacity remains insufficient despite Rwampara opening, creating potential saturation pressure.",
          "response": "Accelerate planned CTE construction."
        },
        {
          "topic": "contact_followup_gap",
          "finding": "Contact follow-up remains below target at 63.1% against a 95% target, compromising interruption of chains of transmission.",
          "response": "Train, deploy, and motivate community relays."
        },
        {
          "topic": "essential_medicines_gap",
          "finding": "Essential medicines are insufficient in targeted HGRs, weakening care continuity.",
          "response": "Advocate for MEG supply."
        },
        {
          "topic": "ipc_material_gap_nord_kivu",
          "finding": "IPC materials (PPE, DLM, chlorine) are insufficient in Nord-Kivu, increasing nosocomial risk.",
          "response": "Urgent IPC supply reinforcement."
        },
        {
          "topic": "weak_alert_reporting",
          "finding": "Alert reporting remains weak in Ituri and Sud-Kivu, delaying case detection.",
          "response": "Strengthen community surveillance."
        },
        {
          "topic": "resource_gap",
          "finding": "Insufficient resources across all pillars slow operations; the SitRep cites a USD 21.5M gap.",
          "response": "Resource mobilization."
        }
