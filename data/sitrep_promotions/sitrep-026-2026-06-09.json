      "response_indicators": {
        "highlights": [
          "37 new confirmed cases including 12 deaths were reported in Ituri, concentrated in Mongbwalu, Rwampara, Bunia, Tchomia, and Lita.",
          "Tchomia was newly reported as an affected health zone.",
          "Eight confirmed patients were declared recovered: seven in Nyankunde and one in Mongbwalu.",
          "Medical care activities were launched at Ebola treatment centers in Bunia and Rwampara."
        ],
        "context": [
          "The SitRep describes a porous border with Uganda and South Sudan, more than one million displaced people in Ituri, mining-site movement, and armed groups as response-context constraints."
        ],
        "laboratory": [
          "Nord-Kivu had 182 results pending because of reagent insufficiency.",
          "RADIONE PCR provider training is listed as a priority action within J+2."
        ],
        "ipc": [
          "IPC evaluations in Ituri found low scores across nine health facilities in Bunia and Aru.",
          "Eight Butembo providers were assessed after exposure risk; six were classified high risk and quarantined."
        ],
        "crec": [
          "Nord-Kivu risk-communication activities reached households, schools, community actors, local radios, and demobilized-camp settings.",
          "Sud-Kivu risk-communication activities included school and relay briefings and Ebola posters at ports and strategic Bukavu points.",
          "In Ituri, a traditional practitioner who had been briefed alerted on a suspected escaped case with hemorrhagic signs, enabling transfer to a treatment center.",
          "Community feedback raised concerns about treatment-center care, slow safe-burial/decontamination response, crowded markets, IPC input needs, and exam-related crowding."
        ],
        "logistics_security": [
          "Supplies were delivered to multiple Ituri health-zone locations, including Tchomia.",
          "The response reported 31 vehicles and two functional ambulances.",
          "Armed-group activity in Djugu, Irumu, and Mambasa limited humanitarian access in affected or at-risk health zones."
        ],
        "challenges": [
          "Reluctance to post-mortem swabbing can delay confirmation and underestimate cases.",
          "Standardized treatment-center capacity remains insufficient despite the Rwampara opening.",
          "Contact follow-up remains weak at 61.1% versus a 95% target.",
          "Generic essential-medicine supply gaps persist in targeted referral hospitals.",
          "Nord-Kivu IPC material gaps include PPE, DLM, and chlorine.",
          "Alert reporting remains weak in all three provinces.",
          "The SitRep lists an outstanding response financing gap of USD 21.5 million."
        ],
        "priority_actions_24_72h": [
          "Train providers on RADIONE PCR use.",
          "Brief providers and community agents on MVE surveillance and SBC in affected or high-risk zones.",
          "Catch up contact follow-up in Ituri.",
          "Reinforce IPC and training in Nyankunde and other nosocomial zones.",
          "Deploy a daily standardized dashboard with KPIs by pillar.",
          "Catch up pending Nord-Kivu laboratory samples.",
          "Extend Nord-Kivu CREC to 15,000 households.",
          "Provide Sud-Kivu mobility, internet, and communication-credit support."
        ],
        "kinshasa_preparedness_visit": [
          "The visual annex shows a preparedness assessment visit to a Kinshasa hospital; no named contacts are promoted from the contact page."
        ]
      },
