{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.arcede.com/schemas/bdbv-2026/public_calibration_status.schema.json",
  "title": "BDBV Public Calibration Status",
  "type": "object",
  "required": [
    "schema_version",
    "outbreak_id",
    "as_of",
    "snapshot_date",
    "status",
    "ledger_rows",
    "open_commitments",
    "resolved_commitments",
    "blocks",
    "resolver_caveats"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "outbreak_id": {
      "type": "string"
    },
    "as_of": {
      "type": "string"
    },
    "snapshot_date": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "ledger_rows": {
      "type": "integer",
      "minimum": 0
    },
    "open_commitments": {
      "type": "integer",
      "minimum": 0
    },
    "resolved_commitments": {
      "type": "integer",
      "minimum": 0
    },
    "next_resolution_date": {
      "type": [
        "string",
        "null"
      ]
    },
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "public_group_id",
          "registered_at",
          "resolution_date",
          "commitment_count",
          "open_count",
          "resolved_count",
          "status"
        ],
        "properties": {
          "public_group_id": {
            "type": "string"
          },
          "registered_at": {
            "type": "string"
          },
          "resolution_date": {
            "type": "string"
          },
          "horizon_days": {
            "type": [
              "string",
              "integer"
            ]
          },
          "commitment_count": {
            "type": "integer",
            "minimum": 0
          },
          "open_count": {
            "type": "integer",
            "minimum": 0
          },
          "resolved_count": {
            "type": "integer",
            "minimum": 0
          },
          "remaining_days_from_snapshot_as_of": {
            "type": [
              "integer",
              "string"
            ]
          },
          "status": {
            "type": "string"
          },
          "control_roles": {
            "type": "object",
            "additionalProperties": {
              "type": "integer"
            }
          },
          "public_value_tiers": {
            "type": "object",
            "additionalProperties": {
              "type": "integer"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "resolver_caveats": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
